{
  "name": "opencode-evolve",
  "version": "0.1.1",
  "description": "Safe local skill management plugin for OpenCode",
  "author": "Xeelix",
  "license": "MIT",
  "type": "module",
  "main": "./dist/plugin.js",
  "types": "./dist/plugin.d.ts",
  "homepage": "https://github.com/Xeelix/opencode-evolve#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Xeelix/opencode-evolve.git"
  },
  "bugs": {
    "url": "https://github.com/Xeelix/opencode-evolve/issues"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "skills",
    "agent-skills",
    "ai-agent",
    "developer-tools"
  ],
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    }
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "cd playground && EVOLVE_DEBUG=1 opencode --print-logs --log-level DEBUG",
    "dev:run": "cd playground && EVOLVE_DEBUG=1 opencode run",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "pack:check": "npm pack --dry-run"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.15.13"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  }
}
